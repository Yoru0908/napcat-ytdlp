# ===========================================
# NapCat Video Bot 环境配置文件
# ===========================================

# QQ 机器人配置
MASTER_QQ=123456789                    # 管理员QQ号，只有这个QQ可以控制机器人
NAPCAT_ACCOUNTQQ=987654321            # 机器人QQ号
NAPCAT_TOKEN=your_napcat_token         # NapCat API Token

# 服务端口配置
FLASK_HOST=0.0.0.0                     # Video Bot 绑定地址
FLASK_PORT=5000                        # Video Bot Web端口
NAPCAT_HTTP_PORT=3000                  # NapCat HTTP API端口
NAPCAT_WS_PORT=3001                    # NapCat WebSocket端口
NAPCAT_WEBUI_PORT=6099                 # NapCat WebUI端口

# 下载配置
DOWNLOAD_DIR=/tmp/alist_downloads      # 下载目录
MAX_CONCURRENT_TASKS=2                 # 最大并发下载任务数

# Alist 网盘配置
ALIST_PORT=5244                        # Alist Web端口
ALIST_USERNAME=admin                    # Alist 用户名
ALIST_PASSWORD=your_alist_password     # Alist 密码
ALIST_PUBLIC_URL=https://alist.yourdomain.com  # Alist 公网访问地址

# LLM 配置 (可选，用于智能命令解析)
LLM_API_KEY=your_minimax_api_key       # MiniMax API Key
LLM_API_URL=https://api.minimaxi.com/v1/chat/completions
LLM_MODEL=MiniMax-M2.5

# ===========================================
# 存储后端配置 (选择其中一种)
# ===========================================

# 本地存储
STORAGE_TYPE=local
LOCAL_DOWNLOAD_PATH=/mnt/downloads

# S3 兼容存储 (AWS S3, 阿里云OSS, 腾讯云COS等)
# STORAGE_TYPE=s3
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET=your_bucket
# S3_REGION=us-east-1

# Cloudflare R2
# STORAGE_TYPE=r2
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET=your_bucket
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# 阿里云OSS
# STORAGE_TYPE=oss
# OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
# OSS_ACCESS_KEY_ID=your_access_key
# OSS_SECRET_ACCESS_KEY=your_secret_key
# OSS_BUCKET=your_bucket

# 腾讯云COS
# STORAGE_TYPE=cos
# COS_SECRET_ID=your_secret_id
# COS_SECRET_KEY=your_secret_key
# COS_REGION=ap-beijing
# COS_BUCKET=your_bucket

# ===========================================
# 其他配置
# ===========================================

# 日志级别
LOG_LEVEL=INFO

# 是否启用调试模式
DEBUG=false

# 公网访问配置
VIDEOBOT_PUBLIC_URL=https://videobot.yourdomain.com

# 反向代理配置 (如果使用)
PROXY_ENABLED=false
PROXY_DOMAIN=yourdomain.com
